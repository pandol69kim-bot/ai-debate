# ============================
# AI Arena - Environment Variables
# ============================
# Copy this file to .env and fill in your API keys

# AI API Keys (required)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# AI Models (optional - defaults shown)
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-opus-4-8
GEMINI_MODEL=gemini-2.0-flash-exp
JUDGE_MODEL=gpt-4o

# Security
SECRET_KEY=your-super-secret-key-at-least-32-characters-long
DEBUG=false

# Database (docker-compose overrides these)
DATABASE_URL=postgresql+asyncpg://arena:arena_pass@postgres:5432/arena_db
DATABASE_URL_SYNC=postgresql://arena:arena_pass@postgres:5432/arena_db

# Redis (docker-compose overrides)
REDIS_URL=redis://redis:6379/0

# Frontend
NEXT_PUBLIC_API_URL=http://localhost
